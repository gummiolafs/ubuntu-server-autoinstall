#cloud-config
autoinstall:
  version: 1
  locale: is_IS.UTF-8
  keyboard:
    layout: is
  timezone: Atlantic/Reykjavik
  ssh:
    install-server: true
    allow-pw: false
  packages:
    - qemu-guest-agent
  storage:
    config:
      - type: disk
        id: disk0
        match:
          size: largest
        ptable: gpt
        wipe: superblock-recursive
        preserve: false
        grub_device: true
      - type: partition
        id: part_efi
        device: disk0
        size: 512M
        flag: boot
        grub_device: true
        preserve: false
      - type: format
        id: fmt_efi
        fstype: fat32
        volume: part_efi
        preserve: false
      - type: partition
        id: part_root
        device: disk0
        size: -1
        preserve: false
      - type: format
        id: fmt_root
        fstype: ext4
        volume: part_root
        preserve: false
      - type: mount
        id: mount_root
        device: fmt_root
        path: /
      - type: mount
        id: mount_efi
        device: fmt_efi
        path: /boot/efi
  identity:
    realname: gummiolafs
    username: gummiolafs
    hostname: ubuntu
    password: "$6$rounds=656000$5dOE1Ns/he7g3InW$4zvSAVoxIvEeyg1OeVZKhXsM/DoZ0pq0.YTBo4KuUUq9F/lim7tUNUaEZTONwX9Cpsd7cPtLkvS4kcfBhUtPR1"
  late-commands:
    - mkdir -p /target/home/gummiolafs/.ssh
    - |
      echo 'ssh-rsa  gummiolafs@gummiolafs.is' > /target/home/gummiolafs/.ssh/authorized_keys
    - curtin in-target --target=/target -- chown -R gummiolafs:gummiolafs /home/gummiolafs/.ssh
    - curtin in-target --target=/target -- chmod 700 /home/gummiolafs/.ssh
    - curtin in-target --target=/target -- chmod 600 /home/gummiolafs/.ssh/authorized_keys
    - curtin in-target --target=/target -- useradd -m -s /bin/bash -G sudo hermes
    - mkdir -p /target/home/hermes/.ssh
    - |
      echo 'ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIL/DNqdI8Rjmr8ggYRzZC5ATJht8cP6mg2QKLeldW/7D hermes@proxmox.g87.is' > /target/home/hermes/.ssh/authorized_keys
    - curtin in-target --target=/target -- chown -R hermes:hermes /home/hermes/.ssh
    - curtin in-target --target=/target -- chmod 700 /home/hermes/.ssh
    - curtin in-target --target=/target -- chmod 600 /home/hermes/.ssh/authorized_keys
    - |
      echo 'PasswordAuthentication no' > /target/etc/ssh/sshd_config.d/99-disable-password.conf
    - |
      echo '%sudo ALL=(ALL) NOPASSWD: ALL' > /target/etc/sudoers.d/99-passwordless
    - curtin in-target --target=/target -- chmod 440 /etc/sudoers.d/99-passwordless
    - curtin in-target --target=/target -- systemctl enable qemu-guest-agent || true
    - curtin in-target --target=/target -- systemctl enable ssh
